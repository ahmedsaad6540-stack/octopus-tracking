# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=your_service_role_key

# Tracking
APP_BASE_URL=http://localhost:8000

# Security – غيرهم بقيم عشوائية طويلة قبل الـ prod
IP_HASH_SALT=change_me_to_random_string
UA_HASH_SALT=change_me_too

# Affiliate Postback (اختياري في الـ dev)
IMPACT_SECRET=
DIGISTORE_IP_ALLOW=

# Debug
ENV=dev
LOG_LEVEL=info
